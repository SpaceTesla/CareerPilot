# Gemini API key (Use GOOGLE_API_KEY as the variable name)
GOOGLE_API_KEY=your-gemini-api-key

# Model selection (optional, defaults to gemini-2.5-flash)
# Use any of: gemini-2.5-flash-lite, gemini-2.5-flash, gemini-2.5-pro
# Or use settings.models.FLASH in code for autocomplete!
MODEL_NAME=gemini-2.5-flash

# Temperature (0.0 - 2.0)
TEMPERATURE=0.0

# Authentication (optional for local development)
# Set AUTH_REQUIRED=true in semi-production/production
AUTH_REQUIRED=false
# Required when AUTH_REQUIRED=true or when sending Authorization bearer tokens
JWT_SECRET=replace-with-strong-secret
JWT_ALGORITHM=HS256

# Database URLs
# Local host runs:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/careerpilot

# Docker Compose (service DNS name "db")
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/careerpilot